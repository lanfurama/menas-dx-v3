# ============================================================
# MENAS DX v3 - Environment Variables Example
# Copy this file to .env and update with your values
# 
# IMPORTANT: Vite chỉ expose các biến có prefix VITE_
# Sensitive data (passwords, API keys) nên được handle qua backend
# ============================================================

# PostgreSQL Database Configuration
# Note: Database connection nên được handle qua backend API
VITE_DB_HOST=localhost
VITE_DB_PORT=5432
VITE_DB_NAME=menas_dx_config
VITE_DB_USER=postgres
# DB_PASSWORD không nên expose ở client-side

# Zalo ZNS Configuration
VITE_ZALO_OA_ID=your_zalo_oa_id
VITE_ZALO_APP_ID=your_zalo_app_id
# ZALO_SECRET_KEY và ZALO_ACCESS_TOKEN nên được handle qua backend

# AI Configuration
VITE_AI_DEFAULT_MODEL=claude
VITE_AI_OLLAMA_ENDPOINT=http://localhost:11434
# AI API keys (Claude, OpenAI, Gemini) nên được handle qua backend

# Application
VITE_PORT=5173
