# ============================================================
# Backend Environment Variables (Node.js/Express)
# File này dùng cho backend API server
# ============================================================

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=menas_dx_config
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false

# Database Connection String (alternative)
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/menas_dx_config

# Zalo ZNS Configuration
ZALO_OA_ID=your_zalo_oa_id
ZALO_APP_ID=your_zalo_app_id
ZALO_SECRET_KEY=your_zalo_secret_key
ZALO_ACCESS_TOKEN=

# AI Configuration - API Keys
AI_CLAUDE_API_KEY=sk-ant-api03-...
AI_OPENAI_API_KEY=sk-...
AI_GEMINI_API_KEY=AIza...
AI_OLLAMA_ENDPOINT=http://localhost:11434

# Application
NODE_ENV=development
PORT=3000
API_PORT=3000

# Security
JWT_SECRET=your_jwt_secret_here_change_in_production
SESSION_SECRET=your_session_secret_here_change_in_production

# CORS
CORS_ORIGIN=http://localhost:5173
