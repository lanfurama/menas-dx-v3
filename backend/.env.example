# Backend Environment Variables
# File này chỉ là example, thực tế dùng .env ở root directory
# Config cho database chứa config (menas_dx_config)
# Database này chứa table db_config, ai_config, zalo_config
# Database trong table db_config là database bên ngoài mà hệ thống sẽ kết nối đến
CONFIG_DB_HOST=localhost
CONFIG_DB_PORT=5432
CONFIG_DB_NAME=menas_dx_config
CONFIG_DB_USER=postgres
CONFIG_DB_PASSWORD=your_password_here
CONFIG_DB_SSL=false

# Server config
PORT=3000
CORS_ORIGIN=http://localhost:5173
